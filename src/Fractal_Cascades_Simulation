{"cells":[{"cell_type":"code","source":"import numpy as np\nimport matplotlib.pyplot as plt\nimport pandas as pd\n\n# --- 1. Simulation Parameters (14-year Chandra observation window) ---\nyears = 14\ndays = years * 365\ntime_axis = np.linspace(0, years, days)\n\nrho_crit = 10.0           # Critical topological threshold\nresidual_pressure = 0.015 # Permanent topological residual pressure of the SNR\nfractal_noise_std = 0.03  # Vacuum fluctuations (noise)\n\n# --- 2. Arrays for data recording ---\nstress_field = np.zeros(days)\nxray_emission = np.zeros(days)\nstandard_cooling = 100 * np.exp(-time_axis / 4) # Classic, smooth exponential cooling\n\n# Initial conditions (just below the critical threshold)\ncurrent_rho = 9.2\n\n# --- 3. The DIT Cascade Simulation ---\nfor i in range(days):\n    # 3.1 Stress accumulates via dimensional frustration and vacuum fluctuations\n    noise = np.random.normal(0, fractal_noise_std)\n    current_rho += residual_pressure + noise\n    \n    flare_intensity = 0\n    # 3.2 Symmetry breaking (Topological Fracture)\n    if current_rho >= rho_crit:\n        # Energy release according to DIT metric: Δf ∝ (ρ - ρ_crit)^1.5\n        flare_intensity = 150 * (current_rho - rho_crit + 0.1)**1.5\n        \n        # Snap-In: The vacuum relaxes abruptly (fractal collapse)\n        current_rho -= np.random.uniform(0.3, 1.2) \n        \n    stress_field[i] = current_rho\n    # Measured X-ray luminosity is base cooling + topological flares\n    xray_emission[i] = standard_cooling[i] + flare_intensity\n\n# --- 4. Data Export ---\ndf = pd.DataFrame({\n    \"Year\": time_axis,\n    \"Topological_Stress\": stress_field,\n    \"Simulated_Xray_Luminosity\": xray_emission,\n    \"Standard_Model_Prediction\": standard_cooling\n})\ndf.to_csv('M83_Fractal_Cascades.csv', index=False)\nprint(\"✅ Chandra-DIT Simulation saved: 'M83_Fractal_Cascades.csv'\")\n\n# --- 5. Visualization for the Paper ---\nfig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 8), sharex=True)\n\n# NOTE: The \"r\" prefix prevents \\r (Carriage Return) errors with LaTeX syntax in matplotlib\nax1.plot(time_axis, stress_field, color='purple', linewidth=1.5, label=r'Topological Stress ($\\rho$)')\nax1.axhline(rho_crit, color='red', linestyle='--', label=r'Critical Threshold ($\\rho_{crit}$)')\nax1.set_title(\"Hidden Vacuum Dynamics: Dimensional Frustration Accumulation\")\nax1.set_ylabel(\"Local Topological Stress\")\nax1.legend()\nax1.grid(True, alpha=0.3)\n\nax2.plot(time_axis, standard_cooling, color='gray', linestyle='--', linewidth=2, label='Standard Astrophysical Model (Smooth Decay)')\nax2.plot(time_axis, xray_emission, color='cyan', linewidth=1.5, label='DIT Prediction (Fractal X-ray Flares)')\nax2.set_title(\"Observable Output: Episodic X-ray Fluctuations in M83 SNRs\")\nax2.set_xlabel(\"Observation Time (Years)\")\nax2.set_ylabel(\"X-ray Luminosity (Arbitrary Units)\")\nax2.legend()\nax2.grid(True, alpha=0.3)\n\n# Dark theme for \"Deep Space\" aesthetic (Optional for plotting)\nplt.style.use('dark_background')\nfig.patch.set_facecolor('#111111')\nax1.set_facecolor('#111111')\nax2.set_facecolor('#111111')\n\nplt.tight_layout()\nplt.show()","outputs":[],"execution_count":null,"metadata":{}}],"metadata":{"colab":{"from_bard":true},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}
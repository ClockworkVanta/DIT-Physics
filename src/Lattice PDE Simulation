{"cells":[{"cell_type":"code","source":"import numpy as np\nimport matplotlib.pyplot as plt\n\n# =====================================================================\n# DIT-Physics: Topological Monte Carlo (TMC) Lattice PDE Simulation\n# Focus: Macroscopic Symmetry Breaking (SU(3) -> SU(2))\n# Author: Frank Sutter / M. Eng.\n# =====================================================================\n\n# 1. System Parameters\nN = 40                      # Grid Resolution (N x N nodes)\nsteps = 150                 # Temporal increments\ncritical_threshold = 10.0   # Hadronization threshold (rho_crit)\nk_transfer = 0.25           # Transfer coefficient for lateral shear stress\nbase_pressure = 0.15        # Baseline compression pressure\n\n# 2. Initialization of the Spatial Matrix\nstress = np.zeros((N, N))\nactive = np.ones((N, N), dtype=bool)\n\n# Geometric pressure profile (Gaussian distribution simulating dimensional frustration)\nx, y = np.meshgrid(np.linspace(-1, 1, N), np.linspace(-1, 1, N))\npressure_profile = base_pressure * np.exp(-(x**2 + y**2) * 4) + 0.05\n\n# Arrays for plotting\nsnapshots = [50, 90, 130] # Timesteps to capture for the paper\nfig, axes = plt.subplots(1, 3, figsize=(15, 5))\n\n# 3. Spatiotemporal Evolution Loop\nfor t in range(steps):\n    # Add pressure to all active nodes\n    stress[active] += pressure_profile[active]\n    \n    # Check for topological fracture (Saddle-Node Bifurcation)\n    failed_this_step = (stress > critical_threshold) & active\n    \n    # Capture snapshots for visualization\n    if t in snapshots:\n        idx = snapshots.index(t)\n        axes[idx].imshow(active, cmap='magma')\n        axes[idx].set_title(f\"Step {t}\")\n        axes[idx].axis('off')\n        \n    # Process the fractal cascade (stress redistribution)\n    if np.any(failed_this_step):\n        failed_indices = np.argwhere(failed_this_step)\n        \n        for (i, j) in failed_indices:\n            # Node collapses, SU(3) symmetry breaks locally\n            active[i, j] = False\n            \n            # Redistribute excess geometric tension to orthogonal neighbors\n            transfer_amount = stress[i, j] * k_transfer\n            \n            for di, dj in [(-1, 0), (1, 0), (0, -1), (0, 1)]:\n                ni, nj = i + di, j + dj\n                # Ensure boundary conditions are respected\n                if 0 <= ni < N and 0 <= nj < N:\n                    stress[ni, nj] += transfer_amount\n                    \n            # Node has dissipated its stress\n            stress[i, j] = 0.0\n\n# 4. Final Visualization\nplt.suptitle(\"Fractal Symmetry Breaking: Formation of the Attractor\", fontsize=16)\nplt.tight_layout()\nplt.show()\n\nprint(\"✅ Lattice PDE Simulation completed successfully.\")","outputs":[],"execution_count":null,"metadata":{}}],"metadata":{"colab":{"from_bard":true},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}